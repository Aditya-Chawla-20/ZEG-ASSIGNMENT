# Database - PostgreSQL with PostGIS
DATABASE_URL=postgresql+psycopg2://postgres:password@db:5432/landscope

# Analysis CRS - UTM Zone 14N for Brazos County, Texas
ANALYSIS_CRS=EPSG:32614
ANALYSIS_CRS_EPSG=32614

# Demo county
DEMO_COUNTY=Brazos
DEMO_COUNTY_FIPS=041

# API settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# Frontend (Vite)
VITE_API_URL=http://localhost:8000

# Performance limits
MAX_BUFFER_METERS=5000
MAX_MANUAL_FEATURES=50
MAX_COORDINATES_PER_FEATURE=1000
MAX_PARCEL_SEARCH_LIMIT=100
