# LandScope Backend Environment Configuration
# Copy to .env and adjust as needed.

# Database (PostgreSQL with PostGIS)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/landscope

# Coordinate reference systems
ANALYSIS_CRS=EPSG:32614
ANALYSIS_CRS_EPSG=32614
WGS84_CRS=EPSG:4326
WGS84_EPSG=4326

# Demo data
DEMO_COUNTY=Brazos
DEMO_COUNTY_FIPS=041

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=INFO

# Geometry limits
MAX_BUFFER_METERS=5000.0
MIN_BUFFER_METERS=0.0
MAX_MANUAL_FEATURES=50
MAX_COORDINATES_PER_FEATURE=1000
MAX_PARCEL_SEARCH_LIMIT=100
DEFAULT_PARCEL_SEARCH_LIMIT=20

# Numerical tolerances
SLIVER_TOLERANCE_SQM=0.01
AREA_INVARIANT_TOLERANCE_SQM=1.0

# Constraint priority order
CONSTRAINT_PRIORITY=["wetlands","floodplain","transmission","manual_exclusion"]
